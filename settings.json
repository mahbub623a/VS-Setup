{
    "workbench.iconTheme": "material-icon-theme",
    "workbench.startupEditor": "none",
    "editor.fontSize": 21,
    "editor.formatOnPaste": true,
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "line",
    "editor.cursorWidth": 3,
    "editor.mouseWheelZoom": true,
    "editor.cursorBlinking": "expand",
    "terminal.integrated.fontSize": 18,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "explorer.confirmPasteNative": false,
    "editor.formatOnType": true,
    "editor.guides.bracketPairs": "active",
    "editor.stickyScroll.enabled": false,
    "workbench.colorCustomizations": {
        "sideBar.background": "#232a30",
        "sideBar.foreground": "#D4D4D4",
        "editor.background": "#303841",
        "editor.foreground": "#D4D4D4",
        "statusBar.background": "#1e2329",
        "statusBar.foreground": "#D4D4D4",
        "activityBar.background": "#1e2329",
        "activityBar.foreground": "#D4D4D4",
        "titleBar.activeBackground": "#1e2329",
        "titleBar.activeForeground": "#D4D4D4",
        "titleBar.inactiveBackground": "#1e2329",
        "titleBar.inactiveForeground": "#D4D4D4",
        "tab.activeBackground": "#303841",
        "tab.activeForeground": "#D4D4D4",
        "tab.inactiveBackground": "#252b33",
        "tab.inactiveForeground": "#A0A0A0",
        "editorGroupHeader.tabsBackground": "#252b33",
        "terminal.background": "#1f242a",
        "terminal.foreground": "#D4D4D4",
        "panel.background": "#1f242a",
        "editorCursor.foreground": "#fff",
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "support.function.stream", // This targets cin, cout, cerr, clog, etc.
                "settings": {
                    "foreground": "#dddddd"
                }
            },
            {
                "scope": "variable",
                "settings": {
                    "foreground": "#dddddd"
                }
            }
        ]
    },
    "files.autoSave": "afterDelay",
    "editor.minimap.autohide": true,
    "editor.minimap.enabled": false,
    "editor.fontFamily": "Cascadia code, Comic Mono",
    "editor.fontWeight": "500",
    "editor.fontLigatures": true,
    "workbench.colorTheme": "Sublime Text 4 Theme",
    "cSpell.userWords": [
        "apna",
        "Mahbub",
        "Mahbubur",
        "Rahman",
        "Tamanna",
        "Tasnuva"
    ],
    "terminal.integrated.enableMultiLinePasteWarning": "never",
}